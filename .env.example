# Local Site Walk - ローカル設定の例
# 実際の値は .env にコピーして編集してください(.env はGit管理されません)

# 案件データ・動画・生成物を保存するディレクトリ(リポジトリ外を推奨)
# Windows の例: C:\Users\<username>\LocalSiteWalkData
# 未設定時の既定値: <ホームディレクトリ>/LocalSiteWalkData
LSW_DATA_DIR=

# バックエンドの待ち受けポート(既定: 8000)
LSW_PORT=8000

# フロントエンドからAPIへ直接アクセスする場合のベースURL
# (通常はViteのdevプロキシを使うため空でよい)
VITE_API_BASE_URL=
